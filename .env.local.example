# Email Configuration (Nodemailer - for sending emails)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
RESTAURANT_EMAIL=hello@burgerbarn.com

# IMAP Configuration (for retrieving contact form emails)
IMAP_EMAIL=your_email@gmail.com
IMAP_PASSWORD=your_app_password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Admin Secret (for securing the emails API endpoint)
ADMIN_SECRET=your_secure_admin_secret_here
